# SendGrid Configuration - Copiez ce contenu dans votre fichier .env
# Remplacez TA_CLÉ_API_ICI par votre vraie clé API SendGrid

SENDGRID_API_KEY=TA_CLÉ_API_ICI
FROM_EMAIL=noreply@talentagency.com
FROM_NAME=Talent & Agency

# Instructions:
# 1. Copiez ces lignes dans un nouveau fichier nommé ".env"
# 2. Remplacez TA_CLÉ_API_ICI par votre clé API SendGrid (commence par SG.)
# 3. Changez noreply@talentagency.com par votre email si besoin
# 4. Redémarrez votre serveur après avoir créé le fichier .env
