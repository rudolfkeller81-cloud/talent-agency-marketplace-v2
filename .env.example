# =============================================================================
# VARIABLES D'ENVIRONNEMENT - MARKETPLACE TALENT AGENCY
# =============================================================================
# Copiez ce fichier en .env et remplissez vos valeurs réelles
# =============================================================================
# 
# 🚨 IMPORTANT: 
# - Ne jamais committer le fichier .env (déjà dans .gitignore)
# - Utiliser des clés différentes pour développement et production
# - Garder ce fichier à jour avec les nouvelles variables
# =============================================================================

# =============================================================================
# ENVIRONNEMENT
# =============================================================================
NODE_ENV=development
PORT=3001

# =============================================================================
# STRIPE - PAIEMENTS & ABONNEMENTS POUR AGENCES
# =============================================================================
# Configuration des clés Stripe pour les paiements et abonnements des agences

# 🔑 OBTENIR VOS CLÉS STRIPE :
# 1. Créez un compte sur https://dashboard.stripe.com/register
# 2. Allez dans "Developers" > "API keys"
# 3. Copiez les clés de test (sk_test_... et pk_test_...)
# 4. Pour la production, utilisez les clés live (sk_live_... et pk_live_...)
# 5. Configurez les webhooks pour les notifications d'abonnement

# Clés Stripe (mode test - à remplacer avec vos vraies clés)
STRIPE_SECRET_KEY=sk_test_...VOTRE_CLÉ_SECRÈTE_ICI
STRIPE_PUBLISHABLE_KEY=pk_test_...VOTRE_CLÉ_PUBLIQUE_ICI
STRIPE_WEBHOOK_SECRET=whsec_...VOTRE_WEBHOOK_SECRET_ICI

# Configuration de l'abonnement Agency Pro (1 jour gratuit, 9.99$/mois)
SUBSCRIPTION_TRIAL_DAYS=1
SUBSCRIPTION_MONTHLY_PRICE=999  # 9.99$ en cents
SUBSCRIPTION_CURRENCY=usd
SUBSCRIPTION_PRODUCT_NAME="Agency Pro"
SUBSCRIPTION_PRODUCT_DESCRIPTION="Accès illimité aux talents et analytics avancés"

# URLs pour les webhooks et redirections
STRIPE_SUCCESS_URL=https://votredomaine.com/settings?subscription=success
STRIPE_CANCEL_URL=https://votredomaine.com/settings?subscription=cancel
STRIPE_WEBHOOK_URL=https://votredomaine.com/webhooks/stripe

# URL de votre application pour les webhooks
# En développement: http://localhost:3001
# En production: https://votredomaine.com
BASE_URL=http://localhost:3001

# URL de votre site pour les webhooks et notifications
VAPID_SUBJECT=https://votredomaine.com
VAPID_PUBLIC_KEY=BNjWjNHbR3NGgkLDnEZQaDsck6rRBxyWHe-J0OFLbEylQqUbPJ3B4_6_ME2izkmfh8QgzzapSd7Y2y-0KBVWo3I
VAPID_PRIVATE_KEY=oLfebSRGZebeTHMFmZgiUTuEjOyaZPRf2_5VBocvPdo

# Configuration du serveur
PORT=3001
NODE_ENV=development

# URL de production (Render) - utilisée pour CSP/CORS
# PRODUCTION_URL=https://votre-app.onrender.com

# Google OAuth (si utilisé)
GOOGLE_CLIENT_ID=votre_google_client_id
GOOGLE_CLIENT_SECRET=votre_google_client_secret_1234567890abcdef1234567890abcdef12345678

# =============================================================================
# GOOGLE OAUTH - AUTHENTIFICATION
# =============================================================================
# Client ID Google OAuth (obtenu depuis Google Cloud Console)
GOOGLE_CLIENT_ID=574506459380-26bsp1pn6dc5dgb72okl9ic7bet7b36l.apps.googleusercontent.com

# =============================================================================
# SÉCURITÉ CORS - ORIGINES AUTORISÉES
# =============================================================================
# Développement - Séparer par des virgules sans espaces
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://127.0.0.1:3000,https://127.0.0.1:3000

# Production - Exemple:
# ALLOWED_ORIGINS=https://votredomaine.com,https://www.votredomaine.com,https://app.votredomaine.com

# =============================================================================
# BASE DE DONNÉES
# =============================================================================
# En développement local : SQLite (pas besoin de DATABASE_URL)
DB_PATH=./database.sqlite

# En production (Render) : PostgreSQL
# DATABASE_URL sera fourni automatiquement par Render quand vous créez une base PostgreSQL
# Format : postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://user:password@host:5432/talent_agency

DB_BACKUP_PATH=./backups/talent_agency_backup.db

# =============================================================================
# UPLOADS DE FICHIERS
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Types de fichiers autorisés (séparés par des virgules)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/webm,application/pdf

# =============================================================================
# CLOUDINARY - STOCKAGE FICHIERS EN PRODUCTION
# =============================================================================
# En production (Render), les fichiers locaux ne persistent pas.
# Créez un compte gratuit sur https://cloudinary.com (25GB gratuit)
# Puis copiez vos identifiants depuis le Dashboard.
# CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=votre_api_key
# CLOUDINARY_API_SECRET=votre_api_secret

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_FILES=5

# =============================================================================
# SESSIONS
# =============================================================================
SESSION_SECRET=your-secret-key-here-change-in-production
SESSION_TIMEOUT=86400000


# =============================================================================
# API EXTERNES (optionnel)
# =============================================================================
# API pour la géolocalisation
GEO_API_KEY=your-geo-api-key

# API pour les notifications
PUSH_NOTIFICATION_KEY=your-push-notification-key

# =============================================================================
# MONITORING (optionnel)
# =============================================================================
# Sentry pour le monitoring d'erreurs
SENTRY_DSN=https://your-sentry-dsn

# Google Analytics
GA_TRACKING_ID=GA-XXXXXXXXXX

# =============================================================================
# DÉVELOPPEMENT UNIQUEMENT
# =============================================================================
# Activer les logs détaillés
DEBUG=true

# Activer le mode maintenance
MAINTENANCE_MODE=false

# Activer les fonctionnalités expérimentales
EXPERIMENTAL_FEATURES=false

# =============================================================================
# PRODUCTION UNIQUEMENT
# =============================================================================
# URL de l'application
APP_URL=https://votredomaine.com

# Clé de chiffrement pour les données sensibles
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Configuration HTTPS
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 1. Copiez ce fichier: cp .env.example .env
# 2. Remplissez les valeurs réelles dans .env
# 3. Ne jamais partager votre fichier .env
# 4. En production, utilisez toujours des clés live (pas de test)
# 5. Changez tous les secrets par défaut
# =============================================================================
